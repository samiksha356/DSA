#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {

    int n, val;
    int arr[100];
    scanf("%d", &n);
    for(int i=0; i<n; i++){
        scanf("%d", &arr[i]);
    }
    scanf("%d", &val);
    int k=0; 
    for(int i=0; i<n; i++){
        if(arr[i] != val){
            arr[k]=arr[i];
            k++;
        }
    }
    for(int i=0; i<k; i++){
        printf("%d ", arr[i]);
    }
    return 0;
}
