#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {

    int N, X, i, arr[100];
    scanf("%d", &N);
    for(i=0; i<N; i++){
        scanf("%d", &arr[i]);
    }
    scanf("%d", &X);
    for(i=N; i>0; i--)
        arr[i] = arr[i-1];
    arr[0]=X;
    for(i=0; i<=N; i++)
        printf("%d ", arr[i]);
    return 0;
}
