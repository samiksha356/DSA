#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n,i,del,pos=-1;
    scanf("%d", &n);
    int arr[n];
    for(i=0; i<n; i++){
        scanf("%d", &arr[i]);
    }
    scanf("%d", &del);
    for(i=0; i<n; i++){
        if(arr[i]==del){
            pos=i;
            break;
        }
    }
    if(pos != -1){
        for(i=pos ; i<n-1 ; i++){
            arr[i]=arr[i+1];
        }
        n--;
    }
    for(i=0; i<n; i++){
        printf("%d ", arr[i]);
    }
    return 0;
}
