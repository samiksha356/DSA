#include <stdio.h>

#define MAX 100

int stack[MAX];
int top = -1;
int N;

void push(int value) {
    if (top == N - 1) {
        printf("Overflow\n");
        return;
    }
    stack[++top] = value;
}

void pop() {
    if (top == -1) {
        printf("Underflow\n");
        return;
    }
    printf("Popped: %d\n", stack[top--]);
}

void display() {
    if (top == -1) {
        printf("Stack is Empty\n");
        return;
    }
    printf("Remaining Stack:\n");
    for (int i = top; i >= 0; i--) {
        printf("%d\n", stack[i]);
    }
}

int main() {
    int x;

    scanf("%d", &N);

    for (int i = 0; i < 3; i++) {
        scanf("%d", &x);
        push(x);
    }

    pop();

    for (int i = 0; i < 2; i++) {
        scanf("%d", &x);
        push(x);
    }

    for (int i = 0; i < 3; i++) {
        pop();
    }

    display();

    return 0;
}

