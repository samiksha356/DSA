#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int N;
    scanf("%d", &N);
    int list[100];
    for(int i=0; i<N; i++){
        scanf("%d", &list[i]);
    }
    int k;
    scanf("%d", &k);
    for(int i=0; i<k; i++){
        int x, p;
        scanf("%d %d", &x, &p);
        for(int j=N-1; j>=p; j--){
            list[j+1]=list[j];
        }
        list[p]=x;
        N++;
    }
    for(int i=0; i<N; i++){
        printf("%d ", list[i]);
    }
    return 0;
}
